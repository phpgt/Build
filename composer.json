{
	"name": "phpgt/build",
	"description": "Client-side build system for PHP projects.",
	"license": "MIT",

	"require": {
		"php": ">=8.2",
		"ext-json": "*",
		"phpgt/cli": "^1.4",
		"phpgt/sync": "^1.3",
		"webmozart/glob": "v4.4.*",
		"composer/semver": "v3.*"
	},

	"require-dev": {
		"phpunit/phpunit": "^10.1",
		"phpstan/phpstan": "^1.10",
		"phpmd/phpmd": "^2.15",
		"squizlabs/php_codesniffer": "^3.7"
	},

	"autoload": {
		"psr-4": {
			"GT\\Build\\": "./src",
			"Gt\\Build\\": "./src"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"GT\\Build\\Test\\": "./test/phpunit",
			"Gt\\Build\\Test\\": "./test/phpunit"
		}
	},
	"config": {
		"platform": {
			"php": "8.2.0"
		}
	},

	"bin": [
		"bin/build"
	],

	"scripts": {
		"phpunit": "vendor/bin/phpunit --configuration phpunit.xml",
		"phpstan": "vendor/bin/phpstan analyse --level 6 src",
		"phpcs": "vendor/bin/phpcs src --standard=phpcs.xml",
		"phpmd": "vendor/bin/phpmd src/ text phpmd.xml",
		"test": [
			"@phpunit",
			"@phpstan",
			"@phpcs",
			"@phpmd"
		]
	},

	"funding": [
		{
			"type": "github",
			"url": "https://github.com/sponsors/PhpGt"
		}
	]
}
